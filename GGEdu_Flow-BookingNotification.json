b8; font-size: 13px;\">Bitiş</td>\n            <td style=\"padding: 6px 0; color: #1a1a2e; font-size: 13px; font-weight: 600; text-align: right;\">{{ $json.formattedEnd }}</td>\n          </tr>\n        </table>\n      </div>\n\n      <a href=\"{{ $json.meetingUrl }}\"\n         style=\"display: block; background: #2563eb; color: #fff; text-decoration: none;\n                padding: 14px; border-radius: 10px; text-align: center; font-size: 14px; font-weight: 600;\">\n        Derse Katıl →\n      </a>\n\n      <p style=\"color: #94a3b8; font-size: 12px; margin: 20px 0 0; text-align: center;\">\n        Meeting linki: {{ $json.meetingUrl }}\n      </p>\n    </div>\n\n    <div style=\"background: #f8fafc; border-top: 1px solid #e2e8f0; padding: 16px 32px; text-align: center;\">\n      <p style=\"color: #94a3b8; font-size: 11px; margin: 0;\">© 2025 EduFlow</p>\n    </div>\n  </div>\n</body>\n</html>",
