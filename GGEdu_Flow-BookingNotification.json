      "parameters": {
        "jsCode": "const bookingId = $input.first().json.body.BookingId;\nconst startDate = new Date($input.first().json.body.CourseStartDate);\nconst endDate = new Date($input.first().json.body.CourseEndDate);\n\nconst formatDate = (date) => date.toLocaleString('tr-TR', {\n  day: '2-digit', month: 'long', year: 'numeric',\n  hour: '2-digit', minute: '2-digit',\n  timeZone: 'UTC'\n});\n\nreturn [{\n  json: {\n    ...$input.first().json.body,\n    meetingUrl: `https://meet.jit.si/GGEdu-${bookingId}`,\n    formattedStart: formatDate(startDate),\n    formattedEnd: formatDate(endDate),\n  }\n}];"
